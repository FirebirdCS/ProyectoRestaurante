@using Restaurant.Domain.Enums
@model Restaurant.Application.Services.ConsumoCuenta
@{
    ViewData["Title"] = $"Cuenta mesa {Model.MesaNumero}";
    var cerrada = Model.EstadoCuenta == EstadoCuenta.Cerrada;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Cuenta &mdash; Mesa @Model.MesaNumero
        <span class="badge bg-dark">@Model.EstadoCuenta</span>
    </h1>
    <a class="btn btn-outline-secondary btn-sm" asp-controller="Mesas" asp-action="Index">&larr; Volver a mesas</a>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header fw-semibold">Consumo acumulado</div>
            <div class="card-body p-0">
                <table class="table mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Producto</th>
                            <th class="text-center">Cant.</th>
                            <th class="text-end">P. unitario</th>
                            <th class="text-end">Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.TieneConsumo)
                        {
                            <tr><td colspan="4" class="text-center text-muted py-3">Sin consumo registrado.</td></tr>
                        }
                        @foreach (var l in Model.Lineas)
                        {
                            <tr>
                                <td>@l.Producto</td>
                                <td class="text-center">@l.Cantidad</td>
                                <td class="text-end">@l.PrecioUnitario.ToString("C")</td>
                                <td class="text-end">@l.Subtotal.ToString("C")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card">
            <div class="card-header fw-semibold">Total a pagar</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-6">Subtotal</dt>
                    <dd class="col-6 text-end">@Model.Subtotal.ToString("C")</dd>
                    <dt class="col-6">Impuesto (12%)</dt>
                    <dd class="col-6 text-end">@Model.Impuesto.ToString("C")</dd>
                    <dt class="col-6 fs-5">Total</dt>
                    <dd class="col-6 text-end fs-5 fw-bold">@Model.Total.ToString("C")</dd>
                </dl>
            </div>
            @if (!cerrada)
            {
                <div class="card-footer bg-white d-grid gap-2">
                    <form asp-action="Generar" method="post">
                        <input type="hidden" name="cuentaId" value="@Model.CuentaId" />
                        <button class="btn btn-outline-primary w-100" @(Model.TieneConsumo ? "" : "disabled")>
                            Generar cuenta
                        </button>
                    </form>
                    <form asp-action="Cerrar" method="post"
                          onsubmit="return confirm('Cerrar la cuenta y liberar la mesa?');">
                        <input type="hidden" name="cuentaId" value="@Model.CuentaId" />
                        <button class="btn btn-success w-100" @(Model.TieneConsumo ? "" : "disabled")>
                            Cerrar y cobrar
                        </button>
                    </form>
                </div>
            }
            else
            {
                <div class="card-footer bg-white text-success fw-semibold">Cuenta cerrada</div>
            }
        </div>
    </div>
</div>
