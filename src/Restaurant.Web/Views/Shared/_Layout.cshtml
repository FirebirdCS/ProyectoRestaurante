@using Restaurant.Domain.Enums
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sabor Tradicional</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-dark mb-4">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">🍽️ Sabor Tradicional</a>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <ul class="navbar-nav me-auto">
                        @if (User.IsInRole(RolNombre.Mesero) || User.IsInRole(RolNombre.Cajero) || User.IsInRole(RolNombre.Administrador))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Mesas" asp-action="Index">Mesas</a>
                            </li>
                        }
                        @if (User.IsInRole(RolNombre.Cocina) || User.IsInRole(RolNombre.Administrador))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Cocina" asp-action="Index">Cocina</a>
                            </li>
                        }
                    </ul>
                    <span class="navbar-text text-light me-3">
                        @User.FindFirst("FullName")?.Value
                        <span class="badge bg-secondary text-uppercase">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</span>
                    </span>
                    <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                        <button type="submit" class="btn btn-outline-light btn-sm">Cerrar sesion</button>
                    </form>
                }
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @if (TempData["Ok"] is string ok)
            {
                <div class="alert alert-success">@ok</div>
            }
            @if (TempData["Error"] is string err)
            {
                <div class="alert alert-danger">@err</div>
            }
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-4">
        <div class="container py-3">
            &copy; 2026 - Sistema de gestion de restaurante - Fase 1
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
